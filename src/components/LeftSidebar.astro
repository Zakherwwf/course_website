---
const chapters = [
    { title: "Chapter 1: Global Synthesis", url: "/course_website/" },
    { title: "Chapter 2: Regional Focus", url: "/course_website/chapter2/" },
    { title: "Chapter 3: Tunisia Focus", url: "/course_website/chapter3/" },
    { title: "Chapter 4: Threats & Solutions", url: "/course_website/chapter4/" }, // <-- ADD THIS
]

const currentPath = Astro.url.pathname;
---
<aside class="left-sidebar">
    <nav>
        <ul>
            {chapters.map(chapter => {
                const isActive = currentPath.startsWith(chapter.url) &&
                                 (currentPath.length === chapter.url.length || currentPath[chapter.url.length] === '/' || currentPath.endsWith('index.html'));
                // Special case for the homepage
                if (chapter.url === '/course_website/' && currentPath !== '/course_website/' && !currentPath.endsWith('index.html')) {
                    // Don't mark active if it's a sub-page
                }

                return (
                    <li>
                        <a href={chapter.url} class:list={{ active: isActive }}>
                            {chapter.title}
                        </a>
                    </li>
                );
            })}
        </ul>
    </nav>
</aside>

<style lang="scss">
/* ... The SCSS styles are unchanged ... */
</style>